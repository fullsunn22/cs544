with adult_admissions as (
    select
        a.subject_id,
        a.hadm_id,
        a.admittime,
        p.anchor_age
    from mimiciv_hosp.admissions a
    join mimiciv_hosp.patients p
      on a.subject_id = p.subject_id
    where p.anchor_age >= 18
)

Step B: antibiotic times

, antibiotic_orders as (
    select
        hadm_id,
        starttime as abx_time
    from mimiciv_hosp.prescriptions
    where lower(drug) similar to '%(vancomycin|piperacillin|cefepime|ceftriaxone|meropenem|zosyn|azithromycin|levofloxacin)%'
)

Step C: culture times

, culture_orders as (
    select
        hadm_id,
        charttime as culture_time
    from mimiciv_hosp.microbiologyevents
    where charttime is not null
)

Step D: suspected infection

, suspected_infection as (
    select
        a.hadm_id,
        min(
            case
                when c.culture_time <= ab.abx_time
                     and ab.abx_time <= c.culture_time + interval '72 hour'
                then c.culture_time
                when ab.abx_time < c.culture_time
                     and c.culture_time <= ab.abx_time + interval '24 hour'
                then ab.abx_time
            end
        ) as suspicion_time
    from antibiotic_orders ab
    join culture_orders c
      on ab.hadm_id = c.hadm_id
    join adult_admissions a
      on a.hadm_id = ab.hadm_id
    where (
        (c.culture_time <= ab.abx_time and ab.abx_time <= c.culture_time + interval '72 hour')
        or
        (ab.abx_time < c.culture_time and c.culture_time <= ab.abx_time + interval '24 hour')
    )
    group by a.hadm_id
)
Step E: SOFA around infection

, sofa_window as (
    select
        s.hadm_id,
        si.suspicion_time,
        max(case
            when s.starttime between si.suspicion_time - interval '48 hour'
                                and si.suspicion_time + interval '24 hour'
            then s.sofa_24hours
        end) as max_sofa_near_infection
    from mimiciv_derived.sofa s
    join suspected_infection si
      on s.hadm_id = si.hadm_id
    group by s.hadm_id, si.suspicion_time
)

Step F: final sepsis label

select
    hadm_id,
    suspicion_time,
    max_sofa_near_infection,
    case
        when max_sofa_near_infection >= 2 then 1
        else 0
    end as sepsis3_flag
from sofa_window
where max_sofa_near_infection >= 2;
